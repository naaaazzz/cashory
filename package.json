{
  "name": "cashory-demo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "better-auth": "1.5.2",
      "@better-auth/expo": "1.5.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @cashory-demo/db db:push",
    "db:studio": "turbo -F @cashory-demo/db db:studio",
    "db:generate": "turbo -F @cashory-demo/db db:generate",
    "db:migrate": "turbo -F @cashory-demo/db db:migrate"
  },
  "dependencies": {
    "@cashory-demo/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cashory-demo/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.2.19"
}
